generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Organization {
  id                 String   @id @default(cuid())
  name               String
  masterPasswordHash String?
  gstNumber          String?
  panNumber          String?
  address            String?
  city               String?
  state              String?
  
  linkInvoicesLedgers Boolean @default(false)
  linkInvoicesChanged Boolean @default(false)
  inventoryEnabled    Boolean @default(false)
  strictInventoryInvoicing Boolean @default(false)
  currency            String  @default("INR")
  invoiceShowBrandName Boolean @default(true)
  invoiceShowSize      Boolean @default(true)
  invoiceBrandNameLabel String @default("Brand Name")
  invoiceSizeLabel     String @default("Size")
  taxMode              String  @default("manual")
  taxPercentage        Float   @default(0)
  
  accounts      Account[]
  invoices      Invoice[]
  rawMaterials  RawMaterial[]
  wipGoods      WIPGood[]
  finishedGoods FinishedGood[]

  @@index([name])
}

model SystemConfig {
  id                String @id @default("global")
  adminPasswordHash String
  dbVersion         Int    @default(1) // 1 = Floats, 2 = Cents
}

model Account {
  id        String         @id @default(cuid())
  name      String
  category  String         @default("Customer") // "Customer" | "Supplier"
  type      String         // "Direct" | "Agency"
  station   String?
  balance   Int            @default(0) // Stored in cents
  
  orgId     String
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  
  ledger    LedgerEntry[]

  @@index([orgId])
}

model LedgerEntry {
  id          String   @id @default(cuid())
  date        DateTime @default(now())
  party       String?
  station     String?
  amount      Int      @default(0) // Stored in cents
  discount    Int      @default(0) // Stored in cents
  taxOrPaid   Int      @default(0) // Stored in cents
  netAmount   Int      @default(0) // Stored in cents
  items       String?
  payment     Int      @default(0) // Stored in cents
  type        String   // "bill" | "payment"
  paymentMode String?
  
  invoiceId   String?  @unique
  
  accountId   String
  account     Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([date])
}

model Invoice {
  id               String    @id @default(cuid())
  invoiceNo        String
  date             DateTime  @default(now())
  customerName     String
  agencyName       String?
  city             String?
  transport        String?
  transportCharges Int       @default(0) // Stored in cents
  remarks          String?
  marka            String?
  itemsDescription String?
  subtotal         Int       @default(0) // Stored in cents
  discount         Int       @default(0) // Stored in cents
  taxes            Int       @default(0) // Stored in cents
  grandTotal       Int       @default(0) // Stored in cents
  status           String    @default("pending") // "paid" | "pending" | "overdue"
  
  ledgerEntryId    String?   @unique
  
  orgId            String
  organization     Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  
  items            ItemRow[]

  @@index([orgId])
  @@index([date])
  @@index([invoiceNo])
}

model ItemRow {
  id        String   @id @default(cuid())
  sno       Int
  style     String?
  brandName String?
  size      String?
  qty       Int      @default(0)
  rate      Int      @default(0) // Stored in cents
  amount    Int      @default(0) // Stored in cents
  
  finishedGoodId String?
  finishedGood   FinishedGood? @relation(fields: [finishedGoodId], references: [id], onDelete: SetNull)
  
  invoiceId String
  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@index([finishedGoodId])
}

model RawMaterial {
  id            String   @id @default(cuid())
  date          DateTime @default(now())
  name          String
  type          String?
  qty           Int      @default(0)
  qtyUsed       Int      @default(0)
  remarks       String?
  price         Int      @default(0) // Stored in cents
  total         Int      @default(0) // Stored in cents
  location      String?
  invNo         String?
  billerName    String?
  supplierName  String?
  
  orgId         String
  organization  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  
  ledgerEntryId String? @unique

  @@index([orgId])
}

model WIPGood {
  id            String   @id @default(cuid())
  date          DateTime @default(now())
  name          String
  status        String   @default("Started")
  totalCost     Int      @default(0) // Stored in cents
  
  orgId         String
  organization  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  
  rawMaterials  RawMaterialUsage[]
  jobWorks      ManufacturingProcess[]

  @@index([orgId])
}

model RawMaterialUsage {
  id            String   @id @default(cuid())
  wipId         String
  wip           WIPGood  @relation(fields: [wipId], references: [id], onDelete: Cascade)
  
  name          String
  qty           Int
  cost          Int      @default(0) // Stored in cents

  @@index([wipId])
}

model ManufacturingProcess {
  id            String   @id @default(cuid())
  wipId         String
  wip           WIPGood  @relation(fields: [wipId], references: [id], onDelete: Cascade)
  
  name          String
  supplierName  String?
  qty           Int      @default(0)
  price         Int      @default(0) // Stored in cents
  total         Int      @default(0) // Stored in cents
  
  ledgerEntryId String?  @unique

  @@index([wipId])
}

model FinishedGood {
  id            String   @id @default(cuid())
  date          DateTime @default(now())
  name          String
  qty           Int      @default(0)
  size          String?
  cost          Int      @default(0) // Stored in cents
  remarks       String?
  location      String?
  wipBreakdown  String?
  
  supplierName  String?
  ledgerEntryId String?  @unique
  
  orgId         String
  organization  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  itemRows      ItemRow[]

  @@index([orgId])
}
